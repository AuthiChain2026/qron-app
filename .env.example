# qron-app Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local or any file containing real secrets.

# ── Supabase ───────────────────────────────────────────────────────────────────
# Available in your Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Available in your Stripe dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# ── Thirdweb ───────────────────────────────────────────────────────────────────
# Client ID from https://thirdweb.com/dashboard (safe to expose in browser)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id
# Secret key from thirdweb dashboard (never expose publicly)
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
# Target chain for the QRON NFT contract (e.g., "polygon", "ethereum", "base")
NEXT_PUBLIC_THIRDWEB_CHAIN=polygon

# ── NFT / On-chain ─────────────────────────────────────────────────────────────
# Deployed QRON NFT contract address
QRON_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
# Minter wallet private key (signs on-chain mint transactions)
# WARNING: Never commit a real key. Use encrypted env vars in production.
MINTER_PRIVATE_KEY=your-minter-wallet-private-key
# QRON signing key pair for QR code generation
QRON_PRIVATE_KEY=your-qron-private-key
QRON_PUBLIC_KEY=your-qron-public-key

# ── AI / Image Generation ──────────────────────────────────────────────────────
# Fal.ai API key for AI image generation (https://fal.ai)
FAL_KEY=your-fal-ai-api-key
# Replicate API token for alternative AI model access (https://replicate.com)
REPLICATE_API_TOKEN=your-replicate-api-token

# ── SendGrid (Email) ───────────────────────────────────────────────────────────
# SendGrid API key for transactional emails (https://sendgrid.com)
SENDGRID_API_KEY=your-sendgrid-api-key
# Verified sender email address in your SendGrid account
SENDGRID_FROM_EMAIL=hello@yourdomain.com

# ── External Services ──────────────────────────────────────────────────────────
# Base URL of the deployed qron-app (used for absolute URL generation)
QRON_URL=https://your-app.vercel.app
# Optional: URL of the AuthiChain API for cross-platform verification
AUTHICHAIN_API_URL=https://authichain.vercel.app
# Optional: URL for analytics event forwarding
ANALYTICS_API_URL=

# ── QR Fallback ────────────────────────────────────────────────────────────────
# Set to "true" to enable client-side jsQR fallback for QR code scanning.
# Requires public/jsQR.js to be present (download from https://github.com/cozmo/jsQR).
NEXT_PUBLIC_ENABLE_QR_FALLBACK=false
