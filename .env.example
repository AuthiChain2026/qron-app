# ─────────────────────────────────────────────────────────────────────────────
# QRON App — Environment Variables
#
# Copy to .env.local for local dev.
# For production: Vercel → qron-app → Settings → Environment Variables
# ─────────────────────────────────────────────────────────────────────────────

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — used by webhook handler to write profiles/credits
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
# sk_test_... for dev, sk_live_... for production
STRIPE_SECRET_KEY=sk_live_or_test_key
# Run: STRIPE_SECRET_KEY=sk_live_... npx tsx scripts/register-stripe-webhook.ts
# Or:  STRIPE_SECRET_KEY=sk_live_... VERCEL_TOKEN=... bash scripts/register-stripe-webhook.sh
# Registers https://qron.space/api/webhook and sets env vars in Vercel automatically
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_webhook_endpoint

# ─── FAL AI ──────────────────────────────────────────────────────────────────
# https://fal.ai/dashboard/keys — AI QR image generation on purchase
FAL_KEY=your-fal-api-key

# ─── SendGrid ────────────────────────────────────────────────────────────────
# Emails AI-generated QR codes to customers after one-time purchase
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@qron.space

# ─── Thirdweb / NFT ──────────────────────────────────────────────────────────
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=your-thirdweb-client-id
THIRDWEB_SECRET_KEY=your-thirdweb-secret-key
THIRDWEB_MINTER_KEY=your-minter-private-key
CONTRACT_ADDRESS=0x4da4D2675e52374639C9c954f4f653887A9972BE

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Fal.ai ───────────────────────────────────────────────────────────────────
# API key from https://fal.ai/dashboard/keys
# Used for AI QR code generation (illusion-diffusion model)
FAL_KEY=your-fal-api-key

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_from_stripe_webhook_endpoint
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# ─── Email ────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=hello@qron.space

# ─── Custom QRON Stripe Prices ───────────────────────────────────────────────
# Create in Stripe Dashboard → Products → Custom Targeted QRON
# Standard: $49 one-time  |  Premium: $99 one-time  |  Elite: $249 one-time
# Leave blank to use price_data (dynamic pricing — no pre-created product needed)
# ─── AI Story Mode Stripe Prices ─────────────────────────────────────────────
# Create in Stripe Dashboard → Products → AI Story Mode
# Basic: $19  |  Pro: $49  |  Elite: $99  (all one-time)
STRIPE_PRICE_STORY_MODE_BASIC=
STRIPE_PRICE_STORY_MODE_PRO=
STRIPE_PRICE_STORY_MODE_ELITE=

# ─── Custom QRON Stripe Prices ───────────────────────────────────────────────
# Create in Stripe Dashboard → Products → Custom Targeted QRON
# Standard: $49 one-time  |  Premium: $99 one-time  |  Elite: $249 one-time
# Leave blank to use price_data (dynamic pricing — no pre-created product needed)
STRIPE_PRICE_CUSTOM_QRON_STANDARD=
STRIPE_PRICE_CUSTOM_QRON_PREMIUM=
STRIPE_PRICE_CUSTOM_QRON_ELITE=

# ─── NFT Minting (Thirdweb — Base / Base Sepolia) ─────────────────────────────
# Contract address of the deployed QRON ERC-721 contract
QRON_NFT_CONTRACT_ADDRESS=
# Thirdweb server-side secret key (never expose)
THIRDWEB_SECRET_KEY=
# Minter wallet private key used to send mint transactions
THIRDWEB_MINTER_KEY=
# Chain: 'base' for mainnet, 'base-sepolia' for testnet
NEXT_PUBLIC_THIRDWEB_CHAIN=base-sepolia
# Wallet to receive demo minted QRONs (admin batch generation)
DEMO_WALLET_ADDRESS=

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret header value for /api/admin/* endpoints
# Usage: curl -H "x-admin-secret: $ADMIN_SECRET" https://qron.space/api/admin/generate-demos
ADMIN_SECRET=change-me-to-a-long-random-string

# ─── AuthiChain Integration ───────────────────────────────────────────────────
# Base URL of AuthiChain workers (provenance, scan-validate)
AUTHICHAIN_API_URL=https://authichain.com
# Shared API secret for worker-to-worker auth
AUTHICHAIN_API_SECRET=change-me-to-a-long-random-string

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=https://qron.space
NEXT_PUBLIC_APP_URL=https://qron.space
